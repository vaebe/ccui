{
  "name": "docs",
  "version": "1.2.2",
  "description": "vue3-ccui components based on Vite and Vue3",
  "keywords": [
    "components",
    "frontend",
    "jsx",
    "typescript",
    "ui-component",
    "vite",
    "vue",
    "vue-components",
    "vue3",
    "vue3-ccui"
  ],
  "homepage": "https://vaebe.github.io/ccui/",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/vaebe/ccui.git"
  },
  "type": "module",
  "scripts": {
    "predev": "pnpm --filter @vaebe/ccui-icons build && node ../cli/index.js create -t ccui --ignore-parse-error && node ../cli/index.js generate:theme && node ./scripts/generate-llms.mjs",
    "dev": "vitepress dev",
    "docs:build": "vitepress build",
    "docs:preview": "vitepress preview"
  },
  "dependencies": {
    "@vaebe/ccui": "workspace:*",
    "@vaebe/ccui-icons": "workspace:*",
    "@vitepress-code-preview/container": "^1.0.8",
    "@vitepress-code-preview/plugin": "^1.0.6",
    "dayjs": "^1.11.19"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.6",
    "@vitejs/plugin-vue-jsx": "^5.1.5",
    "oxc-minify": "^0.128.0",
    "unocss": "^66.6.8",
    "vite": "catalog:",
    "vite-plus": "catalog:",
    "vite-svg-loader": "^5.1.1",
    "vitepress": "2.0.0-alpha.17"
  }
}
